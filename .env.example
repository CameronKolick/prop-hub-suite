# Copy this file to `.env` and fill in values for your environment.
# The real `.env` is git-ignored — do not commit it.

# ----- Legacy Supabase backend (used by pre-existing pages) -----
# These are safe to commit *in .env.example* with placeholder values.
# In production, the publishable (anon) key is public-safe; the URL is too.
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
VITE_AI_FUNCTIONS_URL=""

# ----- New workflow engine backend (swappable per environment) -----
# Which DataClient implementation to load. Options: "mock" (default), "google" (infra impl).
VITE_DATA_BACKEND="mock"
# Which AuthClient implementation to load. Options: "mock" (default), "firebase".
VITE_AUTH_BACKEND="mock"
# Which LLM backend the workflow engine uses. Options: "stub" (default), "claude".
VITE_LLM_BACKEND="stub"
# Only needed when VITE_LLM_BACKEND=claude. Dev-only; production calls go via the API.
VITE_ANTHROPIC_API_KEY=""
